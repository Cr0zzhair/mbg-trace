		{
			"name": "Laporan Keracunan (MongoDB)",
			"item": [
				{
					"name": "List All Laporan",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/laporan-keracunan",
							"host": ["{{base_url}}"],
							"path": ["laporan-keracunan"]
						}
					}
				},
				{
					"name": "Create Laporan Keracunan",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData._id) {",
									"    pm.collectionVariables.set('laporan_id', jsonData._id);",
									"    console.log('Saved laporan_id:', jsonData._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"jumlah_korban\": 10,\n  \"deskripsi\": \"Siswa mengalami mual dan muntah setelah makan siang\",\n  \"id_sppg\": 1,\n  \"detail_investigasi\": {\n    \"petugas\": \"Dr. Ahmad\",\n    \"hasil_pemeriksaan\": \"Dalam proses pemeriksaan\",\n    \"catatan_lapangan\": \"Sampel makanan diambil untuk lab\",\n    \"status\": \"dalam_proses\"\n  },\n  \"dokumentasi\": [\n    {\n      \"tipe\": \"foto\",\n      \"url\": \"evidence_001.jpg\",\n      \"keterangan\": \"Foto kondisi makanan\"\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/laporan-keracunan",
							"host": ["{{base_url}}"],
							"path": ["laporan-keracunan"]
						},
						"description": "Creates a new poisoning report in MongoDB. The response _id is auto-saved to {{laporan_id}} variable."
					}
				},
				{
					"name": "Get Laporan by ID",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/laporan-keracunan/{{laporan_id}}",
							"host": ["{{base_url}}"],
							"path": ["laporan-keracunan", "{{laporan_id}}"]
						},
						"description": "Uses the {{laporan_id}} saved from Create Laporan"
					}
				},
				{
					"name": "Update Laporan",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"deskripsi\": \"Update: gejala bertambah, beberapa siswa dirawat di RS\",\n  \"jumlah_korban\": 12,\n  \"detail_investigasi\": {\n    \"petugas\": \"Dr. Ahmad\",\n    \"hasil_pemeriksaan\": \"Ditemukan bakteri E.coli pada sampel\",\n    \"catatan_lapangan\": \"Suhu penyimpanan bahan tidak standar\",\n    \"status\": \"selesai\",\n    \"tanggal_investigasi\": \"2026-06-12\"\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/laporan-keracunan/{{laporan_id}}",
							"host": ["{{base_url}}"],
							"path": ["laporan-keracunan", "{{laporan_id}}"]
						},
						"description": "Audit trail is automatically appended (never overwritten)"
					}
				},
				{
					"name": "Delete Laporan",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/laporan-keracunan/{{laporan_id}}",
							"host": ["{{base_url}}"],
							"path": ["laporan-keracunan", "{{laporan_id}}"]
						}
					}
				}
			]
		},
		{
			"name": "Traceability (Cross-DB)",
			"item": [
				{
					"name": "Trace: Report → Supplier",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/trace/report/{{laporan_id}}",
							"host": ["{{base_url}}"],
							"path": ["trace", "report", "{{laporan_id}}"]
						},
						"description": "Full reverse trace: Laporan → SPPG → Menu → Bahan Makanan → Supplier"
					}
				},
				{
					"name": "Trace: Supplier → Reports",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/trace/supplier/1",
							"host": ["{{base_url}}"],
							"path": ["trace", "supplier", "1"]
						},
						"description": "Forward trace: find all poisoning reports linked to supplier's ingredients"
					}
				}
			]
		}
	]
}
