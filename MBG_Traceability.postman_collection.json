{
	"info": {
		"_postman_id": "mbg-trace-collection",
		"name": "MBG Traceability System",
		"description": "Sistem Traceability Program Makan Bergizi Gratis (MBG)\n\nMySQL: Supplier, Bahan Makanan, Menu, Sekolah, SPPG\nMongoDB: Laporan Keracunan\nCross-DB: Traceability Service",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api",
			"type": "string"
		},
		{
			"key": "laporan_id",
			"value": "",
			"type": "string",
			"description": "MongoDB ObjectId from created laporan_keracunan"
		}
	],
