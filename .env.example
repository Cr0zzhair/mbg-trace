APP_NAME="MBG Traceability"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── MySQL ──────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sppg_db
DB_USERNAME=root
DB_PASSWORD=

# ─── MongoDB ────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=mbg_nosql

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
